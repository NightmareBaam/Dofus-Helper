{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-set-size",
    "core:window:allow-set-min-size",
    "opener:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/backend",
          "sidecar": true,
          "args": true
        },
        {
          "name": "backend",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
